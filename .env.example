# --- Database (NeonDB) -------------------------------------------------
# Create a free Postgres at https://neon.tech, copy the *pooled* connection
# string. Leave unset to run on built-in demo data (read-only admin).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# --- Admin panel --------------------------------------------------------
# Password for /admin. If unset, falls back to "admin123" (dev only!).
ADMIN_PASSWORD="change-me"
# Random string used to sign the admin session cookie.
# Generate one: openssl rand -hex 32
AUTH_SECRET="replace-with-a-long-random-string"

# --- Site ---------------------------------------------------------------
# Public URL, used for SEO metadata & sitemap (set to your Vercel domain).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
